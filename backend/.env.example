# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/collabzy
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/collabzy

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# YouTube API Configuration
YOUTUBE_API_KEY=your_youtube_api_key_here

# Instagram API Configuration
# For Instagram Graph API (Business accounts)
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_PAGE_ID=your_instagram_page_id_here

# Razorpay Payment Gateway Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here
PLATFORM_FEE_PERCENTAGE=10

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
